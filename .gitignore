# =============================================
# .gitignore — YOYO B&M Menu Digital
# Generado automáticamente para proyecto
# web estático (HTML, CSS, JS)
# =============================================

# --- Sistema Operativo ---
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.directory

# --- Editores e IDEs ---
# Visual Studio Code
.vscode/
!.vscode/extensions.json
!.vscode/settings.json

# JetBrains (WebStorm, IntelliJ)
.idea/
*.iml
*.iws

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim / NeoVim
*.swp
*.swo
Session.vim
.netrwhist

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock

# --- Dependencias y Paquetes (por si se añade npm en el futuro) ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp/
.pnp.js
.yarn/

# --- Variables de Entorno y Secretos (NUNCA subir al repo) ---
.env
.env.local
.env.*.local
*.env

# --- Archivos de Build / Distribución ---
dist/
build/
.cache/
.parcel-cache/

# --- Herramientas de CI/CD ---
.netlify/
.vercel/

# --- Logs ---
logs/
*.log

# --- Archivos temporales ---
*.tmp
*.temp
*.bak
*.orig
